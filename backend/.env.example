# MongoDB connection string
# Replace the credentials and cluster host with your Atlas connection string.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/google

# Gemini API key used by backend AI features
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeather API key used for air-quality lookups
OPENWEATHER_API_KEY=your_openweather_api_key_here

# JWT signing secret for authentication
JWT_SECRET=change_this_secret_in_production

# Backend server port
PORT=5000
